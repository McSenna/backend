# Copy to .env and fill in values. Do not commit .env.

# MongoDB
MONGO_URI=mongodb://localhost:27017/maslogcare

# Server
PORT=5000
NODE_ENV=development

# JWT (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Default admin (optional; used by seed on first run)
ADMIN_DEFAULT_PASSWORD=MaslogAdmin@2025

# Gmail SMTP (Nodemailer) — required for OTP verification emails
# - EMAIL_USER: your Gmail address
# - EMAIL_PASS: use an App Password, not your normal Gmail password:
#   1. Google Account → Security → 2-Step Verification (enable if needed).
#   2. App passwords → Generate for "Mail" or "Other (Custom name)".
# - EMAIL_HOST / EMAIL_PORT: 465 = SSL (secure), 587 = STARTTLS (use if 465 is blocked).
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=your-16-char-app-password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465

# Optional: use port 587 if 465 is refused (e.g. some networks block 465)
# EMAIL_PORT=587

# Optional (local dev only): if you see "self-signed certificate in certificate chain"
# (e.g. behind corporate proxy/VPN), set below. Never use in production.
# EMAIL_TLS_REJECT_UNAUTHORIZED=false
